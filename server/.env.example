# Database
DATABASE_URL="postgresql://user:password@localhost:5432/miaoji?schema=public"

# JWT — CHANGE THESE in production!
JWT_SECRET="change-me-to-random-string"
JWT_REFRESH_SECRET="change-me-to-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5001
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:3000"

# === AI Configuration ===

# Text Generation (outline, content, analysis)
TEXT_PROVIDER=gemini
TEXT_MODEL=gemini-3-flash-preview
TEXT_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key

# Image Generation (choose: openai / nanobanana)
IMAGE_PROVIDER=openai
IMAGE_MODEL=your-image-model
IMAGE_API_KEY=your-image-api-key
IMAGE_BASE_URL=https://your-image-api/v1
