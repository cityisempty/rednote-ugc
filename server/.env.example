# Database
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/xiaohongshu_platform?schema=public"

# JWT
JWT_SECRET="xhs-platform-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="xhs-platform-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"

# AI Provider Selection: gemini | openai (default: gemini)
AI_PROVIDER=gemini

# Gemini API (used when AI_PROVIDER=gemini)
GEMINI_API_KEY="your-gemini-api-key"

# OpenAI Compatible API (used when AI_PROVIDER=openai)
# Works with OpenAI, DeepSeek, Qwen, Ollama, and any OpenAI-compatible service
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o"
OPENAI_IMAGE_MODEL="dall-e-3"

# CORS
CORS_ORIGIN="http://localhost:3000"
