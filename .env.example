# ============================================================
#  妙记 (MiaoNote) 部署配置
#  使用方法: cp .env.example .env  然后修改下面的值
# ============================================================

# ---------- 数据库 ----------
POSTGRES_DB=miaoji
POSTGRES_USER=miaoji
POSTGRES_PASSWORD=miaoji_secret_change_me

# ---------- 访问端口 ----------
# 部署后访问地址: http://你的服务器IP:3080
APP_PORT=3080

# ---------- JWT 密钥 (务必修改!) ----------
JWT_SECRET=change-me-to-a-random-string-1
JWT_REFRESH_SECRET=change-me-to-a-random-string-2
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- 文本生成 (大纲 / 文案) ----------
TEXT_PROVIDER=gemini
TEXT_MODEL=gemini-3-flash-preview
TEXT_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key

# ---------- 图片生成 ----------
# 提供商: openai / nanobanana
IMAGE_PROVIDER=openai
IMAGE_MODEL=your-image-model
IMAGE_API_KEY=your-image-api-key
IMAGE_BASE_URL=https://your-image-api/v1
